# Copy this file to .env and fill in your values
# .env is git-ignored — never commit API keys!

# Get a free key at https://openweathermap.org/api
OPENWEATHER_API_KEY=your_key_here
# 97b6c01d649012ad3cc035a71f1d36bc 
# Demo key will be rotated
# MQTT broker
# - localhost     → use for Demo 2–4 (local Mosquitto via Docker/Podman)
# - test.mosquitto.org → public broker, no auth, great for Demo 1 or quick tests
# You can override per-command without editing this file:
#   MQTT_BROKER=test.mosquitto.org uv run demo2_cloud_weather.py

MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_TOPIC_PREFIX=meetup/weather
